# ClassBuild API Keys
# Browser keys are entered through the app's Setup page.
# CLI generation reads the LLM_* variables below.

# Required for CLI generation. Any OpenAI-compatible API key works.
LLM_API_KEY=
LLM_BASE_URL=https://ollama.com/v1
LLM_MODEL=kimi-k2.6

# Optional: OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_MODEL are also accepted.

# Optional: Google Gemini API key for infographics and voice narration (TTS).
GEMINI_API_KEY=
